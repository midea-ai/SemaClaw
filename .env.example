# Telegram Bot Token（主 Bot，可被多个群组共用）
TELEGRAM_BOT_TOKEN=

# 主频道管理员的 Telegram User ID
ADMIN_TELEGRAM_USER_ID=

# 主 Bot 绑定的 agent folder（默认 main）
# 注意：isAdmin 权限固定归属 main folder，改为其他 folder 后该 bot 为普通对话入口
# TELEGRAM_AGENT_FOLDER=main

# ===== 飞书 / Feishu =====
# 飞书应用凭证（在飞书开发者后台创建自建应用获取）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# 飞书域名：feishu（默认）| lark | 自定义私有化部署地址
# FEISHU_DOMAIN=feishu

# 飞书主频道管理员的 Open ID（设置后飞书私聊作为 main agent 通道）
# 优先级：ADMIN_TELEGRAM_USER_ID > ADMIN_FEISHU_OPEN_ID > Web-only
# ADMIN_FEISHU_OPEN_ID=

# ===== QQ =====

QQ_APP_ID=     #your_appid
QQ_APP_SECRET=   #your_appsecret
#QQ_SANDBOX=false   # 可选，默认 false

# ===== 微信 / WeChat (iLink Bot) =====
# 设为 true 以启用微信频道（首次启动时会弹出 QR 码扫码登录）
# WECHAT_ENABLED=false
# 绑定到哪个 agent folder（对应 ~/semaclaw/agents/{folder}/），默认 main
# WECHAT_AGENT_FOLDER=main
# iLink Bot API 地址（通常无需修改）
# WECHAT_API_BASE_URL=https://ilinkai.weixin.qq.com

# 全局并发上限（同时处理的最大群组数，默认 5）
MAX_CONCURRENT_AGENTS=5

# 每组消息保留条数上限（默认 100）
MAX_MESSAGES_PER_GROUP=100

# 定时任务轮询间隔（秒，默认 60）
SCHEDULER_INTERVAL_SEC=60

# 数据库路径（默认 ~/.semaclaw/semaclaw.db）
# DB_PATH=~/.semaclaw/semaclaw.db

# Agent 人格数据目录（默认 ~/semaclaw/agents）
# 每个 agent 在此目录下有独立子目录，存放 CLAUDE.md(soul)、memory/、.sema/sessions/
# AGENTS_DIR=~/semaclaw/agents

# Agent 默认工作目录根（默认 ~/semaclaw/workspace）
# 每个 agent 在此目录下有独立工作区，无明确项目上下文时在此工作
# WORKSPACE_DIR=~/semaclaw/workspace

# 全局配置文件路径（默认 ~/.semaclaw/config.json）
# 可配置 per-agent allowedWorkDirs 等，config.json 优先级高于 DB
# SEMACLAW_CONFIG_PATH=~/.semaclaw/config.json

# 将内置skill路径设置为空可关闭内置skill
# SEMACLAW_BUNDLED_SKILLS_DIR=""

# Web UI 访问端口（默认 18788）
# GATEWAY_UI_PORT=18788
# WebSocket 端口（默认 18789）
# GATEWAY_PORT=18789
