{
  "name": "semaclaw",
  "version": "0.1.0-beta.3",
  "description": "Multi-group AI gateway built on sema-code-core",
  "license": "MIT",
  "author": "AIRC Sema Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/midea-ai/SemaClaw.git"
  },
  "homepage": "https://github.com/midea-ai/SemaClaw",
  "bugs": {
    "url": "https://github.com/midea-ai/SemaClaw/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "semaclaw": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "web/dist",
    "README.md",
    "LICENSE"
  ],
  "bundleDependencies": [
    "sema-core"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "build:web": "cd web && npm install && npm run build",
    "dev:web": "cd web && npm run dev",
    "prepublishOnly": "npm run build && npm run build:web"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.9.1",
    "commander": "^12.1.0",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.7",
    "fflate": "^0.8.2",
    "grammy": "^1.34.0",
    "nodejieba": "^3.5.7",
    "qrcode-terminal": "^0.12.0",
    "sema-core": "github:midea-ai/sema-code-core#feature/semaclaw",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
